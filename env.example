# ══════════════════════════════════════════════════════════════════════════════
# HSMetric Stack - Variáveis de Ambiente (EXEMPLO)
# ══════════════════════════════════════════════════════════════════════════════
# ESTE É UM ARQUIVO DE EXEMPLO - NÃO USE EM PRODUÇÃO!
# 
# Para usar:
# 1. Copie este arquivo: cp .env.example .env
# 2. Edite o .env e substitua todos os <PLACEHOLDERS>
# 3. Nunca commite o arquivo .env no Git!
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# COMANDOS ÚTEIS PARA GERAR CREDENCIAIS SEGURAS
# ──────────────────────────────────────────────────────────────────────────────
# Chave de criptografia (33 caracteres base64):
#   openssl rand -base64 33 | tr -d '\n'
#
# Senha forte (48 caracteres hex):
#   openssl rand -hex 24
#
# Hash para Basic Auth do Traefik (formato Apache apr1):
#   printf '%s' 'SUA_SENHA_AQUI' | openssl passwd -apr1 -stdin
#   (O resultado será: usuario:$$apr1$$hash...)
# ──────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════════
# CONFIGURAÇÕES GLOBAIS
# ══════════════════════════════════════════════════════════════════════════════

# Timezone para todos os serviços
# Exemplos: America/Sao_Paulo, America/Belem, America/Recife, UTC
TZ=America/Sao_Paulo

# ══════════════════════════════════════════════════════════════════════════════
# TRAEFIK - Proxy Reverso e SSL
# ══════════════════════════════════════════════════════════════════════════════

# Email para Let's Encrypt (avisos de renovação de certificados)
ACME_EMAIL=<SEU_EMAIL_AQUI>

# Domínio do dashboard do Traefik
TRAEFIK_HOST=<traefik.seudominio.com.br>

# Autenticação do dashboard (formato: usuario:$$apr1$$hash)
# ATENÇÃO: Use $$ (duplo) no .env, não $ (simples)
# Gere com: printf 'SUA_SENHA' | openssl passwd -apr1 -stdin
TRAEFIK_BASIC_AUTH=<admin:$$apr1$$HASH_GERADO_AQUI>

# ══════════════════════════════════════════════════════════════════════════════
# N8N - Automação de Workflows
# ══════════════════════════════════════════════════════════════════════════════

# Versão do n8n
N8N_VERSION=1.82.4

# Domínio principal do n8n
N8N_HOST=<n8n.seudominio.com.br>

# Chave de criptografia (CRÍTICO: não altere após primeira execução!)
# Usada para criptografar credenciais salvas nos workflows
# Gere com: openssl rand -base64 33 | tr -d '\n'
N8N_ENCRYPTION_KEY=<CHAVE_CRIPTOGRAFIA_33_CARACTERES>

# Autenticação básica do n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=<SEU_USUARIO>
N8N_BASIC_AUTH_PASSWORD=<SUA_SENHA_FORTE>

# Recursos avançados
N8N_RUNNERS_ENABLED=true
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true

# ══════════════════════════════════════════════════════════════════════════════
# POSTGRESQL - Banco de Dados
# ══════════════════════════════════════════════════════════════════════════════

# Superusuário do PostgreSQL (admin total)
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASSWORD=<SENHA_SUPER_FORTE_POSTGRES>

# ────────────────────────────────────────────────────────────────────────────
# Banco do n8n
# ────────────────────────────────────────────────────────────────────────────
N8N_DB_NAME=n8n
N8N_DB_USER=n8n_user
N8N_DB_PASSWORD=<SENHA_FORTE_N8N_DB>

# ────────────────────────────────────────────────────────────────────────────
# Banco do Metabase
# ────────────────────────────────────────────────────────────────────────────
METABASE_DB_NAME=metabaseappdb
METABASE_DB_USER=metabase_user
METABASE_DB_PASSWORD=<SENHA_FORTE_METABASE_DB>

# ══════════════════════════════════════════════════════════════════════════════
# REDIS - Cache e Fila
# ══════════════════════════════════════════════════════════════════════════════

# Senha do Redis (usado pelo n8n para filas)
REDIS_PASSWORD=<SENHA_FORTE_REDIS>

# ══════════════════════════════════════════════════════════════════════════════
# PGADMIN - Interface Web PostgreSQL
# ══════════════════════════════════════════════════════════════════════════════
# Profile: apps
# Ativar com: docker compose --profile apps up -d

PGADMIN_HOST=<pgadmin.seudominio.com.br>
PGADMIN_EMAIL=<seu.email@exemplo.com>
PGADMIN_PASSWORD=<SENHA_FORTE_PGADMIN>

# ══════════════════════════════════════════════════════════════════════════════
# PORTAINER - Gerenciamento Docker
# ══════════════════════════════════════════════════════════════════════════════
# Profile: ops
# Ativar com: docker compose --profile ops up -d

PORTAINER_HOST=<portainer.seudominio.com.br>

# ══════════════════════════════════════════════════════════════════════════════
# MINIO - Armazenamento S3
# ══════════════════════════════════════════════════════════════════════════════
# Profile: data
# Ativar com: docker compose --profile data up -d

# Domínios
MINIO_HOST=<s3.seudominio.com.br>              # API S3
MINIO_CONSOLE_HOST=<minio.seudominio.com.br>   # Console web

# Credenciais (access key / secret key)
MINIO_ROOT_USER=<SEU_USUARIO_MINIO>
MINIO_ROOT_PASSWORD=<SENHA_FORTE_MINIO>

# URL de redirecionamento do console
MINIO_BROWSER_REDIRECT_URL=https://<minio.seudominio.com.br>

# ══════════════════════════════════════════════════════════════════════════════
# JUPYTER - Notebooks Python
# ══════════════════════════════════════════════════════════════════════════════
# Profile: data
# Ativar com: docker compose --profile data up -d

JUPYTER_HOST=<jupyter.seudominio.com.br>

# Token de acesso (usado no lugar de senha)
# Gere com: openssl rand -hex 24
JUPYTER_TOKEN=<TOKEN_FORTE_48_CARACTERES>

# ══════════════════════════════════════════════════════════════════════════════
# APACHE SPARK - Processamento Distribuído
# ══════════════════════════════════════════════════════════════════════════════
# Profile: data
# Ativar com: docker compose --profile data up -d

SPARK_HOST=<spark.seudominio.com.br>

# Recursos do worker (ajuste conforme seu servidor)
SPARK_WORKER_MEMORY=3G
SPARK_WORKER_CORES=2

# ══════════════════════════════════════════════════════════════════════════════
# METABASE - Business Intelligence
# ══════════════════════════════════════════════════════════════════════════════
# Profile: bi
# Ativar com: docker compose --profile bi up -d

METABASE_HOST=<bi.seudominio.com.br>

# ══════════════════════════════════════════════════════════════════════════════
# CODE-SERVER - VS Code Web
# ══════════════════════════════════════════════════════════════════════════════
# Profile: lab
# Ativar com: docker compose --profile lab up -d

CODE_HOST=<code.seudominio.com.br>
CODE_SERVER_PASSWORD=<SENHA_FORTE_CODE_SERVER>

# ──────────────────────────────────────────────────────────────────────────────
# FIM DO ARQUIVO
# ──────────────────────────────────────────────────────────────────────────────
# Lembre-se:
# 1. Copie para .env: cp .env.example .env
# 2. Substitua TODOS os <PLACEHOLDERS>
# 3. Use senhas fortes (mínimo 16 caracteres)
# 4. Nunca commite o .env real no Git!
# 5. Mantenha backup seguro do .env em local separado
# ──────────────────────────────────────────────────────────────────────────────
